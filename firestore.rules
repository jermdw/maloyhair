rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This app has exactly one user. Ownership is a custom claim
    // (`owner: true`) set once on her Firebase Auth account via the Admin
    // SDK (see functions/scripts/grant-owner-claim.mjs) — it lands on the
    // auth token itself, so checking it here is a real server-side
    // boundary, not just a UI gate. Google Sign-In alone does not restrict
    // who can authenticate, so this claim check is required, not optional.
    function isOwner() {
      return request.auth != null &&
        request.auth.token.owner == true;
    }

    match /clients/{clientId} {
      allow read, write: if isOwner();
    }

    match /services/{serviceId} {
      allow read, write: if isOwner();
    }

    match /appointments/{appointmentId} {
      allow read, write: if isOwner();
    }

    match /settings/{docId} {
      allow read, write: if isOwner();
    }

    match /messages/{messageId} {
      allow read, write: if isOwner();
    }

    // Read-only reference data imported from the salon's prior DaySmart history.
    // Deliberately separate from /appointments so it never touches the live
    // booking/reminder/billing system (see CLAUDE.md-adjacent import notes).
    match /serviceHistory/{entryId} {
      allow read: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
